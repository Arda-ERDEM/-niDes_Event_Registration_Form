{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "dev": "cross-env PORT=5173 BASE_PATH=/ pnpm -C artifacts/gdg-form dev -- --strictPort",
    "preinstall": "node -e \"const fs=require('fs');const ua=process.env.npm_config_user_agent||'';['package-lock.json','yarn.lock'].forEach((f)=>{if(fs.existsSync(f))fs.rmSync(f,{force:true});});if(!ua.startsWith('pnpm/')){console.error('Use pnpm instead');process.exit(1);}\"",
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck"
  },
  "private": true,
  "devDependencies": {
    "@rollup/rollup-win32-x64-msvc": "^4.60.1",
    "@tailwindcss/oxide-win32-x64-msvc": "^4.2.2",
    "cross-env": "^7.0.3",
    "lightningcss-win32-x64-msvc": "^1.32.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
  }
}
